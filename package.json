{
  "name": "amiclaw",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter game dev",
    "lint": "pnpm exec eslint . && pnpm exec markdownlint-cli2 \"*.md\" \".github/**/*.md\" \"docs/changelog-style-guide.md\"",
    "lint:fix": "pnpm exec eslint . --fix && pnpm exec markdownlint-cli2 --fix \"*.md\" \".github/**/*.md\" \"docs/changelog-style-guide.md\"",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier --check .",
    "build": "pnpm --filter manual build && pnpm --filter game build",
    "test": "pnpm --filter game test",
    "test:run": "pnpm --filter game test:run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.28.0"
  }
}
